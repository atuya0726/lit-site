---
import Layout from '../layouts/Layout.astro';

const googleFormEmbedUrl =
	'https://docs.google.com/forms/d/e/1FAIpQLScQ5soM92WLrIFFdTXzza3D144oB4iXa8ZXBLA61gpgP2iHew/viewform?usp=publish-editor?embedded=true';
---

<Layout title="Contact" description="Lit. への問い合わせページです。">
	<section class="page-hero">
		<p class="eyebrow">— 03 / Contact</p>
		<h1>
			問い合わせ<span class="serif"> .</span>
		</h1>
		<p class="lead">
			体験参加・練習試合・取材など、ご相談はフォームから受け付けています。
		</p>
	</section>

	<section class="layout">
		<aside class="info-card">
			<p class="card-tag">Inquiry</p>
			<h2>お気軽にどうぞ</h2>
			<p>
				ソフトテニスを再開したい方、地域の練習試合を組みたい方、メンバー募集状況のお問い合わせなど、
				どのような内容でも歓迎します。
			</p>
		</aside>

		<div class="form-card">
			<div class="form-head">
				<span class="dot"></span>
				<p>Google Form is embedded below.</p>
			</div>
			<div class="form-frame">
				<iframe
					title="Lit. お問い合わせフォーム"
					src={googleFormEmbedUrl}
					width="100%"
					height="980"
					frameborder="0"
					marginheight="0"
					marginwidth="0"
				>
					読み込んでいます…
				</iframe>
			</div>
		</div>
	</section>
</Layout>

<style>
	.page-hero {
		max-width: 1200px;
		margin: clamp(2rem, 5vw, 4rem) auto 0;
		padding: 0 clamp(1rem, 4vw, 2.5rem);
	}

	.eyebrow {
		margin: 0;
		font-family: var(--font-en);
		font-size: 0.78rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--ink-soft);
	}

	.page-hero h1 {
		margin: 0.6rem 0 0.8rem;
		font-family: var(--font-display);
		font-size: clamp(2.4rem, 5vw + 0.5rem, 4.2rem);
		line-height: 1;
		letter-spacing: -0.03em;
		color: var(--primary);
	}

	.serif {
		color: var(--ink);
	}

	.lead {
		margin: 0;
		max-width: 36rem;
		line-height: 1.9;
		color: var(--ink-soft);
	}

	.layout {
		max-width: 1200px;
		margin: 2.4rem auto 0;
		padding: 0 clamp(1rem, 4vw, 2.5rem);
		display: grid;
		grid-template-columns: 1fr 1.6fr;
		gap: 1.5rem;
		align-items: start;
	}

	.info-card {
		position: sticky;
		top: 6rem;
		padding: clamp(1.6rem, 2.4vw, 2.2rem);
		border-radius: 28px;
		background: linear-gradient(160deg, var(--primary), var(--primary-deep));
		color: var(--secondary);
		box-shadow: var(--shadow-lg);
		overflow: hidden;
	}

	.card-tag {
		margin: 0;
		font-family: var(--font-en);
		font-size: 0.7rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: rgba(248, 249, 250, 0.7);
	}

	.info-card h2 {
		margin: 0.6rem 0 1rem;
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 1.8vw + 1rem, 2rem);
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.info-card p {
		margin: 0;
		line-height: 1.85;
		color: rgba(248, 249, 250, 0.85);
	}

	.meta-list {
		margin: 1.4rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.6rem;
	}

	.meta-list li {
		display: grid;
		grid-template-columns: 70px 1fr;
		gap: 0.6rem;
		padding: 0.7rem 0.9rem;
		background: rgba(248, 249, 250, 0.1);
		border: 1px solid rgba(248, 249, 250, 0.18);
		border-radius: 12px;
	}

	.meta-list span {
		font-family: var(--font-en);
		font-size: 0.7rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(248, 249, 250, 0.75);
		align-self: center;
	}

	.meta-list p {
		margin: 0;
		font-size: 0.92rem;
		color: var(--secondary);
	}

	.form-card {
		padding: clamp(1.2rem, 2vw, 1.6rem);
		border-radius: 28px;
		background: var(--glass-strong);
		border: 1px solid rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		box-shadow: var(--shadow-md);
	}

	.form-head {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.4rem 0.6rem 0.9rem;
	}

	.form-head p {
		margin: 0;
		font-family: var(--font-en);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		color: var(--ink-soft);
	}

	.dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--primary);
		box-shadow: 0 0 0 4px rgba(98, 48, 121, 0.18);
	}

	.form-frame {
		border-radius: 20px;
		overflow: hidden;
		background: #fff;
		border: 1px solid rgba(98, 48, 121, 0.16);
	}

	.note {
		margin: 0.9rem 0.4rem 0;
		font-size: 0.78rem;
		color: var(--ink-soft);
		line-height: 1.7;
	}

	.note code {
		padding: 0.1rem 0.4rem;
		border-radius: 6px;
		background: rgba(98, 48, 121, 0.08);
		color: var(--primary);
		font-size: 0.85em;
	}

	@media (max-width: 960px) {
		.layout {
			grid-template-columns: 1fr;
		}
		.info-card {
			position: static;
		}
	}
</style>

---
import Layout from '../layouts/Layout.astro';
import matchResults from '../data/match-results.json';

type MatchEntry = {
	label: string;
	category: string;
	result: string;
};

type MatchResult = {
	id: string;
	date: string;
	tournament: string;
	entries: MatchEntry[];
};

const latest = (matchResults as MatchResult[]).sort(
	(a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
)[0];

const latestCategories = latest
	? Array.from(new Set(latest.entries.map((e) => e.category)))
	: [];
---

<Layout title="Home" description="Lit. は栃木県で活動するソフトテニスクラブチームです。">
	<section class="hero">
		<div class="hero-inner">

			<h1 class="hero-title">
				<span class="line">Play</span>
				<span class="line accent">sharper,</span>
				<span class="line">together.</span>
			</h1>

			<p class="hero-lead">
				栃木県を拠点に活動するソフトテニスクラブ <strong>Lit.</strong><br />
				時には全力で時には楽しく、ソフトテニスの面白さと楽しさを追いかけているチームです。
			</p>

			<div class="hero-actions">
				<a class="btn btn-primary" href="/practice">
					<span>練習について</span>
					<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
						<path
							d="M5 12h14M13 5l7 7-7 7"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</a>
				<a class="btn btn-ghost" href="/contact">体験参加を相談する</a>
			</div>

			<div class="hero-stats">
				<div>
					<p class="stat-num">1〜2<span>days/週</span></p>
					<p class="stat-label">定期練習</p>
				</div>
				<div>
					<p class="stat-num">経験者<span>welcome</span></p>
					<p class="stat-label">学生時代の経験者向け</p>
				</div>
			</div>
		</div>

		<aside class="hero-aside">
			<p class="aside-eyebrow">Latest Result</p>
			{
				latest && (
					<>
						<p class="aside-date">{latest.date}</p>
						<h2 class="aside-title">{latest.tournament}</h2>
						<div class="aside-tags">
							{latestCategories.map((c) => (
								<span class="aside-tag">{c}</span>
							))}
						</div>
						<ul class="aside-entries">
							{latest.entries.map((entry) => (
								<li class="aside-entry">
									<span class="aside-entry-label">{entry.label}</span>
									<strong class="aside-entry-result">{entry.result}</strong>
								</li>
							))}
						</ul>
					</>
				)
			}
			<a class="aside-link" href="/results">
				すべての試合結果へ
				<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
					<path
						d="M5 12h14M13 5l7 7-7 7"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</a>
		</aside>
	</section>

	<section class="bento">
		<a href="/practice" class="cell cell-lg">
			<div class="cell-head">
				<span class="cell-num">01</span>
				<span class="cell-tag">Practice</span>
			</div>
			<h3>練習について</h3>
			<p>活動日・場所・参加方法をまとめています。初参加の方も歓迎です。</p>
			<span class="cell-cta">View →</span>
		</a>

		<a href="/results" class="cell cell-md">
			<div class="cell-head">
				<span class="cell-num">02</span>
				<span class="cell-tag">Results</span>
			</div>
			<h3>試合結果</h3>
			<p>直近の大会結果と振り返りコメント。</p>
			<span class="cell-cta">View →</span>
		</a>

		<a href="/contact" class="cell cell-md dark">
			<div class="cell-head">
				<span class="cell-num">03</span>
				<span class="cell-tag">Contact</span>
			</div>
			<h3>問い合わせ</h3>
			<p>体験参加 / 練習試合のご依頼など。</p>
			<span class="cell-cta">View →</span>
		</a>
	</section>
</Layout>

<style>
	.hero {
		max-width: 1200px;
		margin: clamp(2rem, 5vw, 4rem) auto 0;
		padding: 0 clamp(1rem, 4vw, 2.5rem);
		display: grid;
		grid-template-columns: 1.55fr 1fr;
		gap: 1.5rem;
		align-items: stretch;
	}

	.hero-inner {
		position: relative;
		padding: clamp(1.6rem, 3vw, 2.6rem);
		border-radius: 28px;
		background: var(--glass-strong);
		border: 1px solid rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(22px);
		-webkit-backdrop-filter: blur(22px);
		box-shadow: var(--shadow-lg);
		overflow: hidden;
	}

	.hero-inner::before {
		content: '';
		position: absolute;
		inset: -1px;
		border-radius: inherit;
		padding: 1px;
		background: linear-gradient(140deg, rgba(98, 48, 121, 0.5), transparent 50%);
		-webkit-mask:
			linear-gradient(#000 0 0) content-box,
			linear-gradient(#000 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		pointer-events: none;
	}

	.hero-meta {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		font-family: var(--font-en);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-soft);
		padding: 0.4rem 0.8rem;
		border-radius: 999px;
		background: rgba(98, 48, 121, 0.08);
	}

	.dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--primary);
		box-shadow: 0 0 0 4px rgba(98, 48, 121, 0.18);
	}

	.hero-title {
		margin: 1.4rem 0 1.2rem;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(2.6rem, 6vw + 0.5rem, 5.4rem);
		line-height: 0.95;
		letter-spacing: -0.04em;
		color: var(--primary);
	}

	.hero-title .line {
		display: block;
	}

	.hero-title .accent {
		font-weight: 400;
		color: var(--ink);
	}

	.hero-lead {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.9;
		color: var(--ink-soft);
		max-width: 36rem;
	}

	.hero-lead strong {
		color: var(--primary);
		font-weight: 700;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 1.8rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.85rem 1.3rem;
		border-radius: 999px;
		font-weight: 600;
		text-decoration: none;
		font-size: 0.92rem;
		transition: all 220ms ease;
	}

	.btn-primary {
		background: var(--primary);
		color: var(--secondary);
		box-shadow: 0 14px 30px -10px rgba(98, 48, 121, 0.6);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 22px 40px -12px rgba(98, 48, 121, 0.7);
	}

	.btn-ghost {
		color: var(--primary);
		border: 1px solid rgba(98, 48, 121, 0.35);
	}

	.btn-ghost:hover {
		background: rgba(98, 48, 121, 0.08);
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 0.9rem 1.2rem;
		margin-top: 2.2rem;
		padding-top: 1.6rem;
		border-top: 1px dashed rgba(98, 48, 121, 0.25);
	}

	.stat-num {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 2vw + 1rem, 2.4rem);
		font-weight: 800;
		color: var(--primary);
		letter-spacing: -0.02em;
		line-height: 1;
	}

	.stat-num span {
		display: inline-block;
		margin-left: 0.35rem;
		font-family: var(--font-en);
		font-size: 0.7rem;
		letter-spacing: 0.1em;
		color: var(--ink-soft);
		font-weight: 500;
	}

	.stat-label {
		margin: 0.5rem 0 0;
		font-size: 0.78rem;
		color: var(--ink-soft);
		letter-spacing: 0.05em;
	}

	.hero-aside {
		position: relative;
		padding: clamp(1.6rem, 2.5vw, 2rem);
		border-radius: 28px;
		background: linear-gradient(160deg, var(--primary), var(--primary-deep));
		color: var(--secondary);
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		overflow: hidden;
		box-shadow: var(--shadow-lg);
	}

	.hero-aside::before {
		content: '';
		position: absolute;
		top: -40%;
		right: -25%;
		width: 320px;
		height: 320px;
		background: radial-gradient(circle, rgba(248, 249, 250, 0.18), transparent 70%);
		pointer-events: none;
	}

	.aside-eyebrow {
		margin: 0;
		font-family: var(--font-en);
		font-size: 0.7rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: rgba(248, 249, 250, 0.7);
	}

	.aside-date {
		margin: 0;
		font-family: var(--font-en);
		font-size: 0.85rem;
		letter-spacing: 0.06em;
		color: rgba(248, 249, 250, 0.78);
	}

	.aside-title {
		margin: 0.2rem 0 0.4rem;
		font-family: var(--font-display);
		font-size: 1.55rem;
		line-height: 1.25;
		font-weight: 700;
	}

	.aside-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		margin-top: 0.2rem;
	}

	.aside-tag {
		display: inline-block;
		padding: 0.18rem 0.55rem;
		font-family: var(--font-en);
		font-size: 0.6rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		background: rgba(248, 249, 250, 0.14);
		border: 1px solid rgba(248, 249, 250, 0.22);
		border-radius: 999px;
		color: rgba(248, 249, 250, 0.82);
	}

	.aside-entries {
		list-style: none;
		margin: 0.5rem 0 0;
		padding: 0;
		display: grid;
		gap: 0.4rem;
	}

	.aside-entry {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 0.8rem;
		padding: 0.7rem 0.9rem;
		background: rgba(248, 249, 250, 0.08);
		border: 1px solid rgba(248, 249, 250, 0.18);
		border-radius: 12px;
	}

	.aside-entry-label {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 0.95rem;
		line-height: 1.2;
		color: rgba(248, 249, 250, 0.92);
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.aside-entry-result {
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 800;
		letter-spacing: -0.01em;
		white-space: nowrap;
	}

	.aside-link {
		margin-top: auto;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding-top: 1rem;
		border-top: 1px solid rgba(248, 249, 250, 0.18);
		text-decoration: none;
		font-size: 0.86rem;
		color: var(--secondary);
	}

	.bento {
		max-width: 1200px;
		margin: 4rem auto 0;
		padding: 0 clamp(1rem, 4vw, 2.5rem);
		display: grid;
		grid-template-columns: 1.4fr 1fr 1fr;
		gap: 1.1rem;
	}

	.cell {
		position: relative;
		padding: clamp(1.4rem, 2vw, 2rem);
		border-radius: 24px;
		background: var(--glass-strong);
		border: 1px solid rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		box-shadow: var(--shadow-md);
		text-decoration: none;
		color: var(--ink);
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		transition: transform 260ms ease, box-shadow 260ms ease;
	}

	.cell:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}

	.cell-lg {
		min-height: 240px;
	}

	.cell-md {
		min-height: 200px;
	}

	.cell.dark {
		background: linear-gradient(160deg, var(--primary), var(--primary-deep));
		color: var(--secondary);
		border-color: rgba(248, 249, 250, 0.15);
	}

	.cell-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.cell-num {
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 800;
		color: var(--primary);
	}

	.cell.dark .cell-num {
		color: var(--secondary);
	}

	.cell-tag {
		font-family: var(--font-en);
		font-size: 0.7rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--ink-soft);
	}

	.cell.dark .cell-tag {
		color: rgba(248, 249, 250, 0.7);
	}

	.cell h3 {
		margin: 0.6rem 0 0;
		font-family: var(--font-display);
		font-size: clamp(1.4rem, 1.6vw + 1rem, 1.8rem);
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.cell p {
		margin: 0;
		line-height: 1.8;
		color: var(--ink-soft);
	}

	.cell.dark p {
		color: rgba(248, 249, 250, 0.78);
	}

	.cell-cta {
		margin-top: auto;
		font-family: var(--font-en);
		font-weight: 600;
		letter-spacing: 0.04em;
		font-size: 0.88rem;
		color: var(--primary);
	}

	.cell.dark .cell-cta {
		color: var(--secondary);
	}

	@media (max-width: 960px) {
		.hero {
			grid-template-columns: 1fr;
		}
		.bento {
			grid-template-columns: 1fr;
		}
	}
</style>

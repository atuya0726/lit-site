---
import Layout from '../layouts/Layout.astro';
import matchResults from '../data/match-results.json';

type MatchEntry = {
	label: string;
	category: string;
	result: string;
};

type MatchResult = {
	id: string;
	date: string;
	tournament: string;
	entries: MatchEntry[];
};

const sorted = (matchResults as MatchResult[]).sort(
	(a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const [feature, ...rest] = sorted;

const formatYear = (d: string) => new Date(d).getFullYear();
const formatMonthDay = (d: string) => {
	const date = new Date(d);
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${month}.${day}`;
};

const uniqueCategories = (entries: MatchEntry[]) =>
	Array.from(new Set(entries.map((e) => e.category)));
---

<Layout title="Results" description="Lit. の大会結果を掲載しています。">
	<section class="page-hero">
		<p class="eyebrow">— 02 / Match Results</p>
		<h1>
			試合結果<span class="serif"> .</span>
		</h1>
		<p class="lead">
			大会ごとの戦績を蓄積しています。
		</p>
	</section>

	{
		feature && (
			<section class="feature">
				<div class="feature-left">
					<p class="feature-eyebrow">Latest</p>
					<p class="feature-date">
						<span class="big">{formatMonthDay(feature.date)}</span>
						<span class="year">/ {formatYear(feature.date)}</span>
					</p>
				</div>
				<div class="feature-right">
					<div class="feature-title">
						<h2>{feature.tournament}</h2>
						<div class="tag-row">
							{uniqueCategories(feature.entries).map((c) => (
								<span class="tag">{c}</span>
							))}
						</div>
					</div>
					<ul class="entry-grid">
						{feature.entries.map((entry) => (
							<li class="entry-card">
								<span class="entry-label">{entry.label}</span>
								<strong class="entry-result">{entry.result}</strong>
							</li>
						))}
					</ul>
				</div>
			</section>
		)
	}

	<section class="archive">
		<header class="archive-head">
			<h2>Archive</h2>
			<p>{rest.length} more {rest.length === 1 ? 'record' : 'records'}</p>
		</header>
		<ul class="list">
			{
				rest.map((item) => (
					<li>
						<div class="row-date">
							<span class="row-md">{formatMonthDay(item.date)}</span>
							<span class="row-y">{formatYear(item.date)}</span>
						</div>
						<div class="row-body">
							<div class="row-title">
								<h3>{item.tournament}</h3>
								<div class="tag-row">
									{uniqueCategories(item.entries).map((c) => (
										<span class="tag tag-light">{c}</span>
									))}
								</div>
							</div>
							<ul class="entry-table">
								{item.entries.map((entry) => (
									<li class="entry-row">
										<span class="entry-label">{entry.label}</span>
										<strong class="entry-result">{entry.result}</strong>
									</li>
								))}
							</ul>
						</div>
					</li>
				))
			}
		</ul>
	</section>
</Layout>

<style>
	.page-hero {
		max-width: 1200px;
		margin: clamp(2rem, 5vw, 4rem) auto 0;
		padding: 0 clamp(1rem, 4vw, 2.5rem);
	}

	.eyebrow {
		margin: 0;
		font-family: var(--font-en);
		font-size: 0.78rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--ink-soft);
	}

	.page-hero h1 {
		margin: 0.6rem 0 0.8rem;
		font-family: var(--font-display);
		font-size: clamp(2.4rem, 5vw + 0.5rem, 4.2rem);
		line-height: 1;
		letter-spacing: -0.03em;
		color: var(--primary);
	}

	.serif {
		color: var(--ink);
	}

	.lead {
		margin: 0;
		max-width: 36rem;
		line-height: 1.9;
		color: var(--ink-soft);
	}

	/* === Feature (Latest) === */
	.feature {
		width: calc(100% - clamp(2rem, 8vw, 5rem));
		max-width: 1200px;
		margin: 2.4rem auto 0;
		padding: clamp(1.6rem, 3vw, 2.6rem);
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: 1.5rem;
		border-radius: 28px;
		background: linear-gradient(160deg, var(--primary), var(--primary-deep));
		color: var(--secondary);
		box-shadow: var(--shadow-lg);
		position: relative;
		overflow: hidden;
	}

	.feature::before {
		content: '';
		position: absolute;
		top: -30%;
		right: -20%;
		width: 360px;
		height: 360px;
		background: radial-gradient(circle, rgba(248, 249, 250, 0.16), transparent 70%);
	}

	.feature-eyebrow {
		margin: 0;
		font-family: var(--font-en);
		font-size: 0.7rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: rgba(248, 249, 250, 0.7);
	}

	.feature-date {
		margin: 0.5rem 0 0;
		font-family: var(--font-display);
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		line-height: 1;
	}

	.big {
		font-size: clamp(2.6rem, 5vw + 0.5rem, 4.6rem);
		font-weight: 800;
		letter-spacing: -0.04em;
	}

	.year {
		font-family: var(--font-en);
		font-size: 0.95rem;
		letter-spacing: 0.08em;
		color: rgba(248, 249, 250, 0.78);
	}

	.feature-title {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		margin-bottom: 1rem;
	}

	.feature-title h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 1.8vw + 1rem, 2.2rem);
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.tag {
		display: inline-block;
		padding: 0.25rem 0.6rem;
		font-family: var(--font-en);
		font-size: 0.62rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		background: rgba(248, 249, 250, 0.14);
		border: 1px solid rgba(248, 249, 250, 0.22);
		border-radius: 999px;
		color: rgba(248, 249, 250, 0.85);
	}

	.tag-light {
		background: rgba(98, 48, 121, 0.07);
		border-color: rgba(98, 48, 121, 0.18);
		color: var(--primary);
	}

	.entry-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 0.7rem;
	}

	.entry-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1rem 1.1rem 1.1rem;
		background: rgba(248, 249, 250, 0.08);
		border: 1px solid rgba(248, 249, 250, 0.18);
		border-radius: 14px;
	}

	.entry-card .entry-label {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 0.92rem;
		color: rgba(248, 249, 250, 0.85);
		line-height: 1.3;
	}

	.entry-card .entry-result {
		font-family: var(--font-display);
		font-size: 1.6rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		line-height: 1;
	}

	/* === Archive === */
	.archive {
		max-width: 1200px;
		margin: 3rem auto 0;
		padding: 0 clamp(1rem, 4vw, 2.5rem);
	}

	.archive-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 1.2rem;
		padding-bottom: 0.8rem;
		border-bottom: 1px solid rgba(98, 48, 121, 0.18);
	}

	.archive-head h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.6rem;
		font-weight: 700;
		color: var(--primary);
	}

	.archive-head p {
		margin: 0;
		font-family: var(--font-en);
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--ink-soft);
	}

	.list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.7rem;
	}

	.list > li {
		display: grid;
		grid-template-columns: 110px 1fr;
		gap: 1.4rem;
		padding: 1.3rem 1.5rem;
		border-radius: 18px;
		background: var(--glass-strong);
		border: 1px solid rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		box-shadow: var(--shadow-md);
		transition: transform 220ms ease;
	}

	.list > li:hover {
		transform: translateY(-2px);
	}

	.row-date {
		display: flex;
		flex-direction: column;
		justify-content: center;
		border-right: 1px dashed rgba(98, 48, 121, 0.25);
		padding-right: 1rem;
	}

	.row-md {
		font-family: var(--font-display);
		font-size: 1.7rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--primary);
		line-height: 1;
	}

	.row-y {
		margin-top: 4px;
		font-family: var(--font-en);
		font-size: 0.74rem;
		letter-spacing: 0.12em;
		color: var(--ink-soft);
	}

	.row-title {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.5rem 0.7rem;
		margin-bottom: 0.7rem;
	}

	.row-title h3 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 700;
	}

	.entry-table {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.3rem;
	}

	.entry-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
		padding: 0.55rem 0.85rem;
		border-radius: 10px;
		background: rgba(98, 48, 121, 0.05);
		border: 1px solid rgba(98, 48, 121, 0.1);
	}

	.entry-row .entry-label {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 0.95rem;
		color: var(--ink);
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.entry-row .entry-result {
		font-family: var(--font-display);
		font-size: 1.05rem;
		font-weight: 800;
		color: var(--primary);
		letter-spacing: -0.01em;
		white-space: nowrap;
	}

	@media (max-width: 880px) {
		.feature {
			grid-template-columns: 1fr;
			padding: clamp(1.4rem, 5vw, 2rem);
		}
		.list > li {
			grid-template-columns: 1fr;
			gap: 0.9rem;
			padding: 1.1rem 1.2rem;
		}
		.row-date {
			border-right: none;
			border-bottom: 1px dashed rgba(98, 48, 121, 0.25);
			padding-right: 0;
			padding-bottom: 0.6rem;
			flex-direction: row;
			align-items: baseline;
			gap: 0.6rem;
		}
		.archive-head {
			flex-wrap: wrap;
			gap: 0.4rem;
		}
	}
</style>
